# Copy to .env next to docker-compose.yml (for Compose) and/or chatbot/.env (for local Node).
#
# --- Docker (infra only): redis, qdrant, ollama ---
#   docker compose up -d
#   docker compose exec ollama ollama pull qwen3:0.6b
#
# --- Run the API on your machine (from chatbot/) ---
#   cp ../.env.example .env   # or set vars in your shell
#   npm install && npm run dev
# Use localhost URLs (not Docker service names) when Node runs on the host:
#   REDIS_URL=redis://127.0.0.1:6379
#   QDRANT_URL=http://127.0.0.1:6333
#   LLM_BASE_URL=http://127.0.0.1:11434/v1

# Persona (shown in greetings and prompts).
CHATBOT_NAME=Asha
APPLICATION_NAME=AI Support Chatbot

# Optional Postgres health check. Default off — no Postgres in default Compose.
# USE_POSTGRES=true
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=support
# PGUSER=postgres
# PGPASSWORD=password

# true = templates + RAG excerpts only (no Ollama). false = RAG + Ollama LLM (recommended).
LLM_MOCK=false
# When the app runs on the host, point at localhost Ollama.
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3:0.6b
# Ollama local does not need a key; leave empty.
# LLM_API_KEY=
# CPU inference can be slow — increase if needed (ms).
# LLM_TIMEOUT_MS=120000

# After changing files under chatbot/knowledge/, rebuild the vector index:
#   cd chatbot && FORCE_INGEST=true npm run ingest

# Copy to .env in this directory (chatbot/) before npm run dev / npm start.
# Start infra from repo root: docker compose up -d

REDIS_URL=redis://127.0.0.1:6379
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=application_docs

CHATBOT_NAME=Asha
APPLICATION_NAME=AI Support Chatbot

# USE_POSTGRES=true only if you want the /health Postgres check (you run Postgres yourself).
LLM_MOCK=false
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen3:0.6b

# true (default) = answers are only text from retrieved knowledge chunks (no LLM paraphrase; safest).
# false = LLM may rewrite snippets (can add generic payment steps not in your docs).
RAG_STRICT_EXCERPT=true

# Chunks to retrieve (higher = more context for merged strict answers). Default 8.
# RAG_TOP_K=8

# Optional: PORT=3000
